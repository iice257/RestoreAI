EXPO_PUBLIC_APP_ENV=development

# Keep the local app in mock mode until real services are linked.
EXPO_PUBLIC_AUTH_MODE=mock
EXPO_PUBLIC_BILLING_MODE=mock
EXPO_PUBLIC_IMAGE_WORKFLOW_MODE=mock

# Public client configuration only. Never put service role keys or provider secrets here.
